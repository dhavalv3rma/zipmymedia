.DS_Store
Thumbs.db
.idea
.vscode

# Git
.git
.gitignore
.gitattributes
.github

# Build artifacts
*.zip
node_modules
vendor

# Local Claude / agent config
.claude
.distignore

# Repo-only docs
README.md
